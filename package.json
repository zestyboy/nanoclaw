{
  "name": "nanoclaw",
  "version": "1.2.12",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "verify:state": "node dist/verify-railway-state.js --mode manual",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "notion-import": "tsx scripts/notion-to-obsidian.ts",
    "railway:dev:deploy": "node --import tsx ./scripts/railway.ts dev deploy",
    "railway:dev:status": "node --import tsx ./scripts/railway.ts dev status",
    "railway:dev:logs": "node --import tsx ./scripts/railway.ts dev logs",
    "railway:prod:status": "node --import tsx ./scripts/railway.ts prod status",
    "railway:prod:logs": "node --import tsx ./scripts/railway.ts prod logs",
    "railway:dev:seed": "node --import tsx ./scripts/seed-railway-dev-state.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.18.0",
    "grammy": "^1.39.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "turndown": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
